---
# =============================================================================
#  VAULT – store this file encrypted with ansible-vault
#  
#  IMPORTANT: This file contains placeholder secrets. Generate your own
#  secrets before deployment (see README.md for instructions).
#  
#  After editing, encrypt with: ansible-vault encrypt vault.yml
# =============================================================================

# Node shared secret (generated once; keep the same value on re-runs)
# Generate with: openssl rand -hex 32
vault_node_key: "REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32"

# OAuth key is generated by /usr/libexec/vpn-user-portal/generate-secrets
# and must NOT be an OpenSSL PEM key.
# This is just a placeholder - the real key will be generated during deployment
vault_oauth_key: |
  -----BEGIN PRIVATE KEY-----
  REPLACE_WITH_ED25519_PRIVATE_KEY_OR_LEAVE_AS_IS
  -----END PRIVATE KEY-----

# WireGuard key pair
# Generate with: wg genkey | tee /tmp/wg.key | wg pubkey
vault_wireguard_private_key: "REPLACE_WITH_OUTPUT_OF_wg_genkey"
vault_wireguard_public_key: "REPLACE_WITH_OUTPUT_OF_wg_pubkey"

# OIDC secrets (only required when auth_module == OidcAuthModule)
# Generate with: pwgen -s 32 1 or openssl rand -hex 16
vault_oidc_clients_secret: "REPLACE_WITH_OIDC_CLIENTS_SECRET"
vault_oidc_crypto_passphrase: "REPLACE_WITH_RANDOM_32_CHAR_STRING"

# Internal CA (used for vpn-daemon mTLS)
# Generate with the commands provided in README.md
vault_ca_crt: |
  -----BEGIN CERTIFICATE-----
  REPLACE_WITH_YOUR_CA_CERTIFICATE
  -----END CERTIFICATE-----

vault_ca_key: |
  -----BEGIN EC PRIVATE KEY-----
  REPLACE_WITH_YOUR_CA_PRIVATE_KEY
  -----END EC PRIVATE KEY-----

# TLS certificate/key for vpn-daemon (can be a self-signed cert signed by vault_ca_crt)
# Generate with the commands provided in README.md
vault_tls_crt: |
  -----BEGIN CERTIFICATE-----
  REPLACE_WITH_YOUR_TLS_CERTIFICATE
  -----END CERTIFICATE-----

vault_tls_key: |
  -----BEGIN EC PRIVATE KEY-----
  REPLACE_WITH_YOUR_TLS_PRIVATE_KEY
  -----END EC PRIVATE KEY-----
